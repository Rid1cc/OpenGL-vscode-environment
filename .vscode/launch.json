{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/OpenGLApp.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "${config:grafika.msys2Root}/mingw64/bin/gdb.exe",
            "setupCommands": [
                { "text": "-enable-pretty-printing",            "ignoreFailures": true },
                { "text": "set pagination off",                 "ignoreFailures": true },
                { "text": "set disable-randomization off",      "ignoreFailures": true },
                { "text": "handle SIGSEGV pass noprint nostop", "ignoreFailures": true },
                { "text": "handle SIG35 pass noprint nostop",   "ignoreFailures": true },
                { "text": "handle SIG40 pass noprint nostop",   "ignoreFailures": true }
            ],
            "preLaunchTask": "Build Debug"
        },
        {
            "name": "Run (no debugger)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/OpenGLApp.exe",
            "args": [],
            "noDebug": true,
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "${config:grafika.msys2Root}/mingw64/bin/gdb.exe",
            "preLaunchTask": "Build Debug"
        },
        {
            "name": "macOS: Debug",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/OpenGLApp",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build",
            "environment": [],
            "externalConsole": false,
            "MIMode": "lldb",
            "setupCommands": [
                { "text": "-enable-pretty-printing", "ignoreFailures": true },
                { "text": "set pagination off",      "ignoreFailures": true }
            ],
            "preLaunchTask": "macOS: Build Debug"
        },
        {
            "name": "macOS: Run (no debugger)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/OpenGLApp",
            "args": [],
            "noDebug": true,
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build",
            "environment": [],
            "externalConsole": false,
            "MIMode": "lldb",
            "preLaunchTask": "macOS: Build Debug"
        }
    ]
}
