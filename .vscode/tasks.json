{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Configure Debug",
            "type": "process",
            "command": "${config:grafika.msys2Root}/usr/bin/bash.exe",
            "args": [
                "--login", "-c",
                "cd \"$1\" && cmake --preset mingw64-debug",
                "_", "${workspaceFolder}"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "PATH": "${config:grafika.msys2Root}\\mingw64\\bin;${config:grafika.msys2Root}\\usr\\bin;${env:PATH}",
                    "MSYSTEM": "MINGW64"
                }
            },
            "problemMatcher": [],
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared", "clear": true }
        },
        {
            "label": "Configure Release",
            "type": "process",
            "command": "${config:grafika.msys2Root}/usr/bin/bash.exe",
            "args": [
                "--login", "-c",
                "cd \"$1\" && cmake --preset mingw64-release",
                "_", "${workspaceFolder}"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "PATH": "${config:grafika.msys2Root}\\mingw64\\bin;${config:grafika.msys2Root}\\usr\\bin;${env:PATH}",
                    "MSYSTEM": "MINGW64"
                }
            },
            "problemMatcher": [],
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared", "clear": true }
        },
        {
            "label": "Build Debug",
            "detail": "Configure + compile (Debug) [Ctrl+Shift+B]",
            "type": "process",
            "command": "${config:grafika.msys2Root}/usr/bin/bash.exe",
            "args": [
                "--login", "-c",
                "cd \"$1\" && cmake --preset mingw64-debug && cmake --build --preset debug",
                "_", "${workspaceFolder}"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "PATH": "${config:grafika.msys2Root}\\mingw64\\bin;${config:grafika.msys2Root}\\usr\\bin;${env:PATH}",
                    "MSYSTEM": "MINGW64"
                }
            },
            "problemMatcher": "$gcc",
            "group": { "kind": "build", "isDefault": true },
            "presentation": { "reveal": "always", "panel": "shared", "clear": true }
        },
        {
            "label": "Build Release",
            "type": "process",
            "command": "${config:grafika.msys2Root}/usr/bin/bash.exe",
            "args": [
                "--login", "-c",
                "cd \"$1\" && cmake --preset mingw64-release && cmake --build --preset release",
                "_", "${workspaceFolder}"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "PATH": "${config:grafika.msys2Root}\\mingw64\\bin;${config:grafika.msys2Root}\\usr\\bin;${env:PATH}",
                    "MSYSTEM": "MINGW64"
                }
            },
            "problemMatcher": "$gcc",
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared", "clear": true }
        },
        {
            "label": "Clean",
            "type": "process",
            "command": "${config:grafika.msys2Root}/usr/bin/bash.exe",
            "args": [
                "--login", "-c",
                "cd \"$1\" && rm -rf build",
                "_", "${workspaceFolder}"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "PATH": "${config:grafika.msys2Root}\\mingw64\\bin;${config:grafika.msys2Root}\\usr\\bin;${env:PATH}",
                    "MSYSTEM": "MINGW64"
                }
            },
            "problemMatcher": [],
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared" }
        },
        {
            "label": "Run",
            "detail": "Build Debug + launch executable",
            "type": "process",
            "command": "${workspaceFolder}/build/OpenGLApp.exe",
            "dependsOn": "Build Debug",
            "options": { "cwd": "${workspaceFolder}/build" },
            "problemMatcher": [],
            "group": { "kind": "test", "isDefault": true },
            "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
        },
        {
            "label": "macOS: Build Debug",
            "type": "shell",
            "command": "cmake --preset macos-debug && cmake --build --preset debug-mac",
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": "$gcc",
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared", "clear": true }
        },
        {
            "label": "macOS: Build Release",
            "type": "shell",
            "command": "cmake --preset macos-release && cmake --build --preset release-mac",
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": "$gcc",
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared", "clear": true }
        },
        {
            "label": "macOS: Clean",
            "type": "shell",
            "command": "rm -rf build",
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": [],
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared" }
        },
        {
            "label": "macOS: Run",
            "detail": "Build Debug + launch executable",
            "type": "shell",
            "command": "./OpenGLApp",
            "dependsOn": "macOS: Build Debug",
            "options": { "cwd": "${workspaceFolder}/build" },
            "problemMatcher": [],
            "group": "test",
            "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
        },
                {
            "label": "Linux: Build Debug",
            "type": "shell",
            "command": "cmake --preset linux-debug && cmake --build --preset debug-linux",
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": "$gcc",
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared", "clear": true }
        },
        {
            "label": "Linux: Build Release",
            "type": "shell",
            "command": "cmake --preset linux-release && cmake --build --preset release-linux",
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": "$gcc",
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared", "clear": true }
        },
        {
            "label": "Linux: Clean",
            "type": "shell",
            "command": "rm -rf build",
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": [],
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared" }
        },
        {
            "label": "Linux: Run",
            "detail": "Build Debug + launch executable",
            "type": "shell",
            "command": "./OpenGLApp",
            "dependsOn": "Linux: Build Debug",
            "options": { "cwd": "${workspaceFolder}/build" },
            "problemMatcher": [],
            "group": { "kind": "test" },
            "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
        }
    ]
}
