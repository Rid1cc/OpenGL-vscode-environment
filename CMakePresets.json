{
    "version": 6,
    "configurePresets": [
        {
            "name": "mingw64-debug",
            "displayName": "MinGW-w64 · Debug",
            "generator": "MSYS Makefiles",
            "binaryDir": "${sourceDir}/build",
            "toolchainFile": "${sourceDir}/cmake/toolchain-mingw64.cmake",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "mingw64-release",
            "inherits": "mingw64-debug",
            "displayName": "MinGW-w64 · Release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "OFF"
            }
        },
        {
            "name": "macos-debug",
            "displayName": "macOS (Clang) · Debug",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build",
            "toolchainFile": "${sourceDir}/cmake/toolchain-macos.cmake",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "macos-release",
            "inherits": "macos-debug",
            "displayName": "macOS (Clang) · Release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "OFF"
            }
        }
        ,
        {
            "name": "linux-debug",
            "displayName": "Linux (GCC) · Debug",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build",
            "toolchainFile": "${sourceDir}/cmake/toolchain-linux.cmake",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "linux-release",
            "inherits": "linux-debug",
            "displayName": "Linux (GCC) · Release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "OFF"
            }
        }
    ],
    "buildPresets": [
        { "name": "debug",       "configurePreset": "mingw64-debug",  "jobs": 4 },
        { "name": "release",     "configurePreset": "mingw64-release", "jobs": 4 },
        { "name": "debug-mac",   "configurePreset": "macos-debug",    "jobs": 4 },
        { "name": "release-mac", "configurePreset": "macos-release",  "jobs": 4 }
        ,
        { "name": "debug-linux",   "configurePreset": "linux-debug",    "jobs": 4 },
        { "name": "release-linux", "configurePreset": "linux-release",  "jobs": 4 }
    ]
}
